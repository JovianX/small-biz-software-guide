{% set canonical = page.url | canonicalUrl(site.url) %}
{% set orgId = (site.url | stripTrailingSlash) ~ '/#organization' %}
{% set webId = (site.url | stripTrailingSlash) ~ '/#website' %}
{% if authors %}
  {% set authorIds = authors %}
{% elif author %}
  {% set authorIds = [author] %}
{% else %}
  {% set authorIds = ['editorial'] %}
{% endif %}
{% set published = date | htmlDate %}
{% set ogImagePath = site.ogImage if site.ogImage else '/assets/og-default.jpg' %}
{% set articleOgImage = ogImagePath | url | absUrl(site.url) %}
{% set homeUrl = (site.url | stripTrailingSlash) ~ '/' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": {{ title | jsonEncode | safe }},
      "description": {{ (description or site.description) | jsonEncode | safe }},
      "datePublished": {{ (published ~ 'T12:00:00.000Z') | jsonEncode | safe }},
      "dateModified": {{ (published ~ 'T12:00:00.000Z') | jsonEncode | safe }},
      "author": [
        {%- for id in authorIds -%}
        {%- set person = people[id] -%}
        {
          "@type": "Person",
          "name": {{ (person.name if person else 'Editorial') | jsonEncode | safe }}
        }{%- if not loop.last -%},{%- endif -%}
        {%- endfor -%}
      ],
      "publisher": { "@id": {{ orgId | jsonEncode | safe }} },
      "image": {{ articleOgImage | jsonEncode | safe }},
      "mainEntityOfPage": { "@type": "WebPage", "@id": {{ canonical | jsonEncode | safe }} },
      "isPartOf": { "@id": {{ webId | jsonEncode | safe }} },
      "articleSection": {{ (type | contentTypeLabel) | jsonEncode | safe }}
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ homeUrl | jsonEncode | safe }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ title | jsonEncode | safe }},
          "item": {{ canonical | jsonEncode | safe }}
        }
      ]
    }
  ]
}
</script>
