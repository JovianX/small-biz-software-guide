---
layout: layouts/base.njk
---

<article class="article article--{{ type }}">
  <header class="article__header">
    <p class="article__meta">
      <span class="type-pill type-pill--{{ type }}">{{ type | contentTypeLabel }}</span>
      <span class="article__sep" aria-hidden="true">·</span>
      <time class="article__time" datetime="{{ date | htmlDate }}">{{ date | readableDate }}</time>
    </p>
    <h1 class="article__title">{{ title }}</h1>
    {% if description %}
    <p class="article__dek">{{ description }}</p>
    {% endif %}
    {% include "partials/byline.njk" %}
  </header>
  <div class="article__body prose">
    {{ content | safe }}
  </div>
  {% if affiliate %}
  {% include "partials/affiliate-notice.njk" %}
  {% endif %}
</article>
{% include "partials/article-jsonld.njk" %}
